NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Auth — JWT for register/login responses (use a strong random value in production)
JWT_SECRET=change-me-use-long-random-string
JWT_EXPIRES_IN=7d

# App + Prisma Client (`src/db/prisma.ts`). On Supabase transaction pooler, include:
#   ?pgbouncer=true&connection_limit=1
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/techscopper?schema=public

# Optional: direct connection for Prisma CLI only (db push / migrate). Use Supabase
# "Direct connection" or port 5432 URI if `db push` errors with prepared statements.
# DIRECT_URL=postgresql://USER:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
# Auth — JWT for register/login responses (use a strong random value in production)
JWT_SECRET=change-me-use-long-random-string
JWT_EXPIRES_IN=7d