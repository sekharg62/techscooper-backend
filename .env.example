NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Auth — JWT for register/login (use a strong random value in production)
JWT_SECRET=change-me-use-long-random-string
JWT_EXPIRES_IN=7d

# PostgreSQL (Supabase / Prisma). On Supabase transaction pooler, add: ?pgbouncer=true&connection_limit=1
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/techscopper?schema=public

# Optional: Prisma CLI only (db push / migrate) — direct port 5432 if pooler errors
# DIRECT_URL=postgresql://USER:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# MongoDB Atlas (optional). Replace user, password, cluster host, and db name with your project.
# Get the real string from Atlas → Database → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://demo_user:demo_password@cluster0.xxxxx.mongodb.net/techscopper?retryWrites=true&w=majority&appName=TechScopper
